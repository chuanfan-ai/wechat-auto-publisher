# 复制到 ~/.wechat-auto-publisher/.env 或 ./.wechat-auto-publisher/.env
# 严禁 commit 真实凭证
#
# ── 公众号 API（必填）────────────────────────────────
# 公众号后台 → 设置与开发 → 基本配置 → 公众号开发信息
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# ── AI 排版 API（v4 必填）────────────────────────────
# chuanfanai.com 的 Gemini 协议中转网关 key
# 也可以在 config.json 的 layout_model.api_key_env 改成别的环境变量名
LAYOUT_API_KEY=
