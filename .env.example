# 复制到 ~/.wechat-auto-publisher/.env 或 ./.wechat-auto-publisher/.env
# 严禁 commit 真实凭证
#
# ── 公众号 API（必填）────────────────────────────────
# 公众号后台 → 设置与开发 → 基本配置 → 公众号开发信息
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# ── 外部 API（v12 统一）────────────────────────────
# chuanfanai.com 的 API key。一把 key 同时管两件事：
#   - 排版（Gemini 协议中转，gemini-3.1-flash-lite）
#   - AI 生图（OpenAI Images 协议，gpt-image-2）
#
# 当 ~/.wechat-auto-publisher/config.json 里的 layout_mode 或 image_mode
# 选了 "external" 时必填；选 "self" / "manual" 时不需要。
#
# 也可以在 config.json 的 external_api.api_key_env 改成别的环境变量名。
EXTERNAL_API_KEY=

# 兼容 v11：老脚本里仍读 LAYOUT_API_KEY 作为兜底（新部署建议改成 EXTERNAL_API_KEY）
# LAYOUT_API_KEY=
